{
  "projectType": "frontend",
  "provider": "github",
  "branchMode": "new",
  "branchPrefix": "feature/claude/",
  "maxReviewRounds": 15,
  "streamOutput": true,
  "yolo": true,
  "claudeBin": "claude",
  "opencodeBin": "opencode",
  "devProvider": "claude",
  "reviewerProvider": "claude",
  "plannerProvider": "claude",
  "devModel": "claude-opus-4-6",
  "reviewerModel": "claude-sonnet-4-6",
  "closerEnabled": true,
  "closerProvider": "claude",
  "closerModel": "claude-opus-4-6",
  "flowctl": ".flow/bin/flowctl",
  "ui": true,
  "notifyWebhook": "",
  "skipOnFailedTask": true,
  "rateLimitTaskRetry": true,
  "rateLimitMaxSleep": 21600,
  "resumeEnabled": true,
  "debug": 2,
  "projectName": "Marz - Frontend",
  "prBase": "dev",
  "worktreeEnabled": true,
  "worktreeBase": "../.rafita-worktrees",
  "worktreeKeep": false,
  "maxFinalRounds": 3,
  "profileExtensions": {
    "dev": "agents/dev.md",
    "reviewer": "agents/reviewer.md",
    "closer": "agents/closer.md",
    "all": ""
  }
}
