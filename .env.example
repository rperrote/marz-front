# marz-front — public client env vars (VITE_*)
# Copy to .env.local for development. Never put secrets here.

VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws
VITE_APP_TITLE=Marz

CLERK_PUBLISHABLE_KEY=pk_
CLERK_SECRET_KEY=sk_

# Backend test API secret (E2E only — must match marz-api TEST_SECRET)
MARZ_TEST_SECRET=

# Sentry — browser SDK (VITE_*). Leave empty locally to keep it as a no-op.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=1.0

# Sentry — SSR Node SDK (no VITE_ prefix, server-only).
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=1.0

# Sentry — sourcemap upload during build (server-only secret).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=marz-lc
SENTRY_PROJECT=javascript-tanstackstart-react

# Grafana Faro — Web Vitals + browser logs/traces a Alloy → Loki/Prometheus.
# Alloy local escucha en :12347/collect. Leave empty para deshabilitar.
VITE_FARO_URL=http://localhost:12347/collect
VITE_FARO_APP_VERSION=dev
VITE_FARO_ENVIRONMENT=local